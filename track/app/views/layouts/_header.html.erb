<header class="w-full bg-white border-b border-gray-200 shadow-sm sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">

    <div class="flex items-center gap-10">
      <h1 class="text-2xl font-bold text-black-600 tracking-tighter">Wan<span class="text-xs align-top">2</span></h1>

      <%
        # 1. クラスを共通変数として定義（一箇所直せば全部変わる）
        nav_base = "px-4 flex items-center h-full text-sm transition"
        active_s = "font-bold text-blue-600 border-b-2 border-blue-600"
        idle_s   = "font-medium text-gray-500 hover:text-gray-900"

        is_dollar_yen_transactions = request.path.start_with?('/dollar_yen_transactions') || request.path.start_with?('/transaction_types')
        is_ledgers = request.path.start_with?('/tax_returns') || request.path.start_with?('/ledgers') || request.path.start_with?('/ledger_csvs') || request.path.start_with?('/ledger_csv_integrations')
        is_settings = request.path.start_with?('/settings')
      %>
      <nav class="hidden md:flex items-center gap-1 h-16">
        <%= link_to t('views.dollar_yen_transactions.index'), dollar_yen_transactions_path, class: "#{nav_base} #{is_dollar_yen_transactions ? active_s : idle_s}" %>
        <%= link_to t('views.ledgers.index'), tax_returns_path, class: "#{nav_base} #{is_ledgers ? active_s : idle_s}" %>
        <%= link_to t('views.settings.index'), settings_accounts_path, class: "#{nav_base} #{is_settings ? active_s : idle_s}" %>
      </nav>
    </div>

    <div class="flex items-center gap-3">
      <div class="flex items-center gap-2 px-3 py-1.5 bg-purple-50 border border-purple-100 rounded-full">
        <span class="w-2 h-2 bg-purple-500 rounded-full animate-pulse"></span>
        <span class="text-xs font-bold text-purple-700 uppercase tracking-wider"><%= user[:network] %></span>
      </div>

      <div class="flex items-center px-3 py-1.5 bg-gray-100 rounded-lg group cursor-pointer hover:bg-gray-200 transition">
        <span class="text-xs font-mono text-gray-600"><%= user[:display_address] %></span>
        <svg class="w-3 h-3 ml-2 text-gray-400 group-hover:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
      </div>

      <%= link_to sessions_logout_path,
                  data: { turbo_method: :post, turbo_confirm: "ログアウトしますか？" },
                  class: "ml-2 p-2 text-gray-400 hover:text-red-500 transition border border-transparent hover:border-red-100 hover:bg-red-50 rounded-lg",
                  title: t('header.logout') do %>

        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
        </svg>
      <% end %>
    </div>
  </div>
</header>

<% if @navs.present? && !is_settings %>
<div class="w-full bg-gray-50 border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 h-12 flex items-center gap-8">
    <nav class="flex gap-6 text-sm">
      <% @navs.each do |nav| %>
        <% if nav[:selected] == true %>
          <a class="text-gray-900 font-bold"><%= nav[:name] %></a>
        <% else %>
          <%= link_to nav[:name], nav[:path], class: "text-gray-500 hover:text-gray-800" %>
        <% end %>
      <% end %>
    </nav>
  </div>
</div>
<% end %>

<!-- imformation -->
<% if notification.present? %>
<div class="bg-white mx-auto max-w-screen-xl py-4">
  <div class="mx-auto flex px-4">
    <div class="mx-auto"><%= notification.message %></div>
  </div>
</div>
<% end %>
