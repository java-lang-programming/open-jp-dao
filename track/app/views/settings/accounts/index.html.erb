<% content_for :title do %>WanWan <%= t('views.settings.index') %><% end %>

<% content_for :header do %>
  <%= render "layouts/header", user: @user, notification: @notification %>
<% end %>

<section class="py-8">
  <div class="grid place-items-center min-h-screen">
    <div class="flex w-full max-w-5xl h-[600px] bg-white overflow-hidden">
      <div class="flex min-h-screen w-full bg-white font-sans text-gray-800">
        <%= render "settings/left_menu" %>
        <main class="flex-1 bg-white">
          <div class="max-w-2xl p-4 pt-6">
            <h2 class="text-xl font-bold mb-2"><%= t('views.settings.accounts.index') %></h2>
            <p class="text-xs text-gray-500 mb-8 leading-relaxed">アカウントの確認、削除ができます。 </p>
            <div class="space-y-1">
              <%= link_to settings_account_info_path do %>
                <div class="flex items-start p-4 hover:bg-gray-50 cursor-pointer transition-colors group">
                  <div class="p-2 mr-4">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                  </div>
                  <div class="flex-1">
                    <h3 class="text-sm font-medium"><%= t('views.settings.account.show') %></h3>
                    <p class="text-xs text-gray-500 mt-0.5">アドレスやENSなどのアカウント情報を確認できます。</p>
                  </div>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-400 self-center" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
              <% end %>
              <%= link_to settings_account_delete_path do %>
                <div class="flex items-start p-4 hover:bg-gray-50 cursor-pointer transition-colors">
                  <div class="p-2 mr-4">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                    </svg>
                  </div>
                  <div class="flex-1">
                    <h3 class="text-sm font-medium"><%= t('views.settings.account.remove') %></h3>
                    <p class="text-xs text-gray-500 mt-0.5">アカウントを削除する方法について説明します。</p>
                  </div>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-400 self-center" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
              <% end %>
            </div>
          </div>
        </main>

        <div class="fixed bottom-6 right-6 flex flex-col space-y-3">
          <div class="bg-white p-3 rounded-xl shadow-lg border border-gray-100 cursor-pointer hover:bg-gray-50">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
          </div>
          <div class="bg-white p-3 rounded-xl shadow-lg border border-gray-100 cursor-pointer hover:bg-gray-50">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<% content_for :footer do %>
  <%= render "layouts/footer" %>
<% end %>
