<div data-modal-target="container" class="fixed inset-0 z-50 items-center justify-center bg-black/50 p-4 hidden">
  <div class="relative w-full max-w-[600px] bg-white rounded-2xl shadow-2xl flex flex-col max-h-[90vh] animate-in fade-in zoom-in duration-200 overflow-hidden">
    <button data-action="click->modal#close" class="absolute top-4 right-4 p-2 hover:bg-gray-100 rounded-full transition-colors z-20">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <%= yield %>
  </div>
</div>
